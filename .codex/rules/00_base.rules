# 00_base.rules (Starlark)
# ============================================================
# OpenAI Codex ExecPolicy Rules (prefix_rule) - Final++
# Strategy: conservative (more prompt)
# - decision: forbidden > prompt > allow
# - match / not_match: inline unit tests (must be valid shell syntax)
# ============================================================

# -----------------------------
# helper wrappers
# -----------------------------
def forbid(pattern, justification, match_examples = None, not_match_examples = None):
    kwargs = {
        "pattern": pattern,
        "decision": "forbidden",
        "justification": justification,
    }
    if match_examples != None:
        kwargs["match"] = match_examples
    if not_match_examples != None:
        kwargs["not_match"] = not_match_examples
    prefix_rule(**kwargs)

def prompt(pattern, justification, match_examples = None, not_match_examples = None):
    kwargs = {
        "pattern": pattern,
        "decision": "prompt",
        "justification": justification,
    }
    if match_examples != None:
        kwargs["match"] = match_examples
    if not_match_examples != None:
        kwargs["not_match"] = not_match_examples
    prefix_rule(**kwargs)

# ============================================================
# 0) Disaster-class (ALWAYS forbidden)
# ============================================================

# Linux/macOS: rm -rf /
forbid(["rm", "-rf", "/"], "禁止高危删除：rm -rf /", match_examples=["rm -rf /"])
forbid(["rm", "-rf", "/*"], "禁止高危删除：rm -rf /*", match_examples=["rm -rf /*"])
forbid(["sudo", "rm", "-rf", "/"], "禁止高危删除：sudo rm -rf /", match_examples=["sudo rm -rf /"])
forbid(["sudo", "rm", "-rf", "/*"], "禁止高危删除：sudo rm -rf /*", match_examples=["sudo rm -rf /*"])

# Windows: forbid deleting system root C:\
forbid(["powershell.exe", "-Command", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：powershell.exe Remove-Item C:\\",
       match_examples=[r"powershell.exe -Command 'Remove-Item -Recurse -Force C:\\'"])
forbid(["powershell.exe", "-c", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：powershell.exe -c Remove-Item C:\\",
       match_examples=[r"powershell.exe -c 'Remove-Item -Recurse -Force C:\\'"])
forbid(["powershell", "-Command", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：powershell Remove-Item C:\\",
       match_examples=[r"powershell -Command 'Remove-Item -Recurse -Force C:\\'"])
forbid(["powershell", "-c", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：powershell -c Remove-Item C:\\",
       match_examples=[r"powershell -c 'Remove-Item -Recurse -Force C:\\'"])
forbid(["pwsh.exe", "-Command", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：pwsh.exe Remove-Item C:\\",
       match_examples=[r"pwsh.exe -Command 'Remove-Item -Recurse -Force C:\\'"])
forbid(["pwsh.exe", "-c", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：pwsh.exe -c Remove-Item C:\\",
       match_examples=[r"pwsh.exe -c 'Remove-Item -Recurse -Force C:\\'"])
forbid(["pwsh", "-Command", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：pwsh Remove-Item C:\\",
       match_examples=[r"pwsh -Command 'Remove-Item -Recurse -Force C:\\'"])
forbid(["pwsh", "-c", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：pwsh -c Remove-Item C:\\",
       match_examples=[r"pwsh -c 'Remove-Item -Recurse -Force C:\\'"])

# Windows cmd wrapper hardening
forbid(["cmd.exe", "/c", "pwsh.exe", "-Command", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：cmd.exe /c pwsh.exe Remove-Item C:\\",
       match_examples=[r"cmd.exe /c pwsh.exe -Command 'Remove-Item -Recurse -Force C:\\'"])
forbid(["cmd", "/c", "pwsh.exe", "-Command", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：cmd /c pwsh.exe Remove-Item C:\\",
       match_examples=[r"cmd /c pwsh.exe -Command 'Remove-Item -Recurse -Force C:\\'"])
forbid(["cmd.exe", "/c", "powershell.exe", "-Command", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：cmd.exe /c powershell.exe Remove-Item C:\\",
       match_examples=[r"cmd.exe /c powershell.exe -Command 'Remove-Item -Recurse -Force C:\\'"])
forbid(["cmd", "/c", "powershell.exe", "-Command", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：cmd /c powershell.exe Remove-Item C:\\",
       match_examples=[r"cmd /c powershell.exe -Command 'Remove-Item -Recurse -Force C:\\'"])

# Common cmd.exe variant: /d /s /c (可选但很值)
forbid(["cmd.exe", "/d", "/s", "/c", "pwsh.exe", "-Command", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：cmd.exe /d /s /c pwsh.exe Remove-Item C:\\",
       match_examples=[r"cmd.exe /d /s /c pwsh.exe -Command 'Remove-Item -Recurse -Force C:\\'"])
forbid(["cmd.exe", "/d", "/s", "/c", "powershell.exe", "-Command", r"Remove-Item -Recurse -Force C:\\"],
       "禁止删除系统目录：cmd.exe /d /s /c powershell.exe Remove-Item C:\\",
       match_examples=[r"cmd.exe /d /s /c powershell.exe -Command 'Remove-Item -Recurse -Force C:\\'"])

# ============================================================
# 1) High impact (PROMPT) - Conservative set
# ============================================================

# ---------- Docker destructive/cleanup ----------
prompt(["docker", "system", "prune", "-a"],
       "可能删除大量镜像/容器/网络/缓存：docker system prune -a（需确认）",
       match_examples=["docker system prune -a"],
       not_match_examples=["docker system prune"])

# 更保守：不带 -a 也提示（很多人以为“没事”，但仍可能删很多）
prompt(["docker", "system", "prune"],
       "会清理未使用资源：docker system prune（需确认）",
       match_examples=["docker system prune"])

prompt(["docker", "builder", "prune", "-a"],
       "可能清空构建缓存：docker builder prune -a（需确认）",
       match_examples=["docker builder prune -a"])
prompt(["docker", "image", "prune", "-a"],
       "可能删除大量镜像：docker image prune -a（需确认）",
       match_examples=["docker image prune -a"])
prompt(["docker", "volume", "prune"],
       "可能删除未使用卷：docker volume prune（需确认）",
       match_examples=["docker volume prune"])
prompt(["docker", "network", "prune"],
       "可能删除未使用网络：docker network prune（需确认）",
       match_examples=["docker network prune"])
prompt(["docker", "container", "prune"],
       "可能删除停止的容器：docker container prune（需确认）",
       match_examples=["docker container prune"])

prompt(["docker", "compose", "down"],
       "会停止并删除容器/网络：docker compose down（需确认）",
       match_examples=["docker compose down"])
prompt(["docker", "compose", "down", "-v"],
       "会删除容器/网络/卷：docker compose down -v（需确认）",
       match_examples=["docker compose down -v"])
prompt(["docker-compose", "down"],
       "会停止并删除容器/网络：docker-compose down（需确认）",
       match_examples=["docker-compose down"])
prompt(["docker-compose", "down", "-v"],
       "会删除容器/网络/卷：docker-compose down -v（需确认）",
       match_examples=["docker-compose down -v"])

# ---------- Git data-loss ----------
prompt(["git", "reset", "--hard"],
       "会丢弃未提交修改：git reset --hard（需确认）",
       match_examples=["git reset --hard"])
prompt(["git", "clean", "-fdx"],
       "会删除未跟踪文件/忽略文件：git clean -fdx（需确认）",
       match_examples=["git clean -fdx"])
prompt(["git", "clean", "-ffdx"],
       "会强力删除未跟踪文件/忽略文件：git clean -ffdx（需确认）",
       match_examples=["git clean -ffdx"])
prompt(["git", "push", "--force"],
       "会强制覆盖远端历史：git push --force（需确认）",
       match_examples=["git push --force"])
prompt(["git", "push", "-f"],
       "会强制覆盖远端历史：git push -f（需确认）",
       match_examples=["git push -f"])

# ---------- Kubernetes destructive ----------
prompt(["kubectl", "delete", "namespace"],
       "会删除整个命名空间及其资源：kubectl delete namespace（需确认）",
       match_examples=["kubectl delete namespace prod"])
prompt(["kubectl", "delete", "ns"],
       "会删除整个命名空间及其资源：kubectl delete ns（需确认）",
       match_examples=["kubectl delete ns prod"])
prompt(["kubectl", "delete", "-f"],
       "会批量删除清单中的资源：kubectl delete -f（需确认）",
       match_examples=["kubectl delete -f k8s.yaml"])
prompt(["helm", "uninstall"],
       "会卸载 Helm Release 并删除资源：helm uninstall（需确认）",
       match_examples=["helm uninstall my-release"])

# ---------- System/service interruption ----------
prompt(["shutdown"], "会关机：shutdown（需确认）", match_examples=["shutdown"])
prompt(["reboot"], "会重启：reboot（需确认）", match_examples=["reboot"])
prompt(["systemctl", "stop"],
       "会停止系统服务：systemctl stop（需确认）",
       match_examples=["systemctl stop nginx"])

# ---------- Windows: potentially destructive admin ops ----------
prompt(["reg", "delete"],
       "会删除注册表项：reg delete（需确认）",
       match_examples=["reg delete HKCU\\Software\\Test /f"])
prompt(["bcdedit"],
       "会修改引导配置：bcdedit（需确认）",
       match_examples=["bcdedit /enum"])
prompt(["diskpart"],
       "磁盘分区工具：diskpart（需确认）",
       match_examples=["diskpart"])

