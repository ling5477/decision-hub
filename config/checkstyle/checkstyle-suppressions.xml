<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD Suppressions 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>

    <!-- 示例：忽略 generated 目录 -->
    <suppress checks=".*" files=".*/generated/.*"/>
    <suppress checks=".*" files=".*/target/.*"/>

</suppressions>
