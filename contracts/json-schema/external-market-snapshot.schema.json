{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decision-hub.guidinglight/contracts/json-schema/external-market-snapshot.schema.json",
  "title": "ExternalMarketSnapshot",
  "description": "Stage2-PoC-B1：global-stock-data / 其他市场数据源的快照。dataJson 与 rawPayloadJson 都禁止丢失。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshotId",
    "traceId",
    "symbols",
    "source",
    "rangeStart",
    "rangeEnd",
    "fetchedAt",
    "dataJson",
    "status",
    "rawPayloadJson"
  ],
  "properties": {
    "snapshotId": { "type": "string", "minLength": 1 },
    "traceId":    { "type": "string", "minLength": 1 },
    "symbols": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "source":         { "type": "string", "enum": ["GLOBAL_STOCK_DATA", "INTERNAL_CACHE", "FAKE"] },
    "rangeStart":     { "type": "string", "format": "date" },
    "rangeEnd":       { "type": "string", "format": "date" },
    "fetchedAt":      { "type": "string", "format": "date-time" },
    "dataJson":       { "type": "string" },
    "sourceVersion":  { "type": ["string", "null"] },
    "status":         { "type": "string", "enum": ["COMPLETED", "PENDING", "FAILED"] },
    "rawPayloadJson": { "type": "string" }
  }
}
