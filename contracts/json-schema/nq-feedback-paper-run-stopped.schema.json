{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decision-hub.guidinglight/contracts/json-schema/nq-feedback-paper-run-stopped.schema.json",
  "title": "PaperRunStoppedPayload",
  "description": "Stage2-PoC-B1：PAPER_RUN_STOPPED payload。",
  "type": "object",
  "additionalProperties": false,
  "required": ["paperRunId", "stoppedAt", "reason", "rawPayloadJson"],
  "properties": {
    "paperRunId":     { "type": "string", "minLength": 1 },
    "stoppedAt":      { "type": "string", "format": "date-time" },
    "reason":         { "type": "string", "minLength": 1 },
    "rawPayloadJson": { "type": "string" }
  }
}
