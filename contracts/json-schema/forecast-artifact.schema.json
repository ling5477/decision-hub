{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decision-hub.guidinglight/contracts/json-schema/forecast-artifact.schema.json",
  "title": "ForecastArtifact",
  "description": "Stage2-PoC-B1：Kronos / 其他时序预测工具的产物。rawPayloadJson 必须保留。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "traceId",
    "symbol",
    "horizon",
    "target",
    "predictions",
    "generatedAt",
    "status",
    "rawPayloadJson"
  ],
  "properties": {
    "artifactId":  { "type": "string", "minLength": 1 },
    "traceId":     { "type": "string", "minLength": 1 },
    "symbol":      { "type": "string", "minLength": 1 },
    "horizon":     { "type": "string", "enum": ["D1", "D5", "D20", "D60"] },
    "target":      { "type": "string", "enum": ["PRICE", "VOLATILITY", "DIRECTION", "VOLUME"] },
    "predictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "value", "confidence"],
        "properties": {
          "date":       { "type": "string", "format": "date" },
          "value":      { "type": "number" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "modelVersion":   { "type": ["string", "null"] },
    "generatedAt":    { "type": "string", "format": "date-time" },
    "status":         { "type": "string", "enum": ["COMPLETED", "PENDING", "FAILED", "TIMEOUT"] },
    "rawPayloadJson": { "type": "string" }
  }
}
