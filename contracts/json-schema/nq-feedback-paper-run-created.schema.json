{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decision-hub.guidinglight/contracts/json-schema/nq-feedback-paper-run-created.schema.json",
  "title": "PaperRunCreatedPayload",
  "description": "Stage2-PoC-B1：PAPER_RUN_CREATED payload。",
  "type": "object",
  "additionalProperties": false,
  "required": ["paperRunId", "candidateId", "strategyName", "requestedBy", "createdAt", "rawPayloadJson"],
  "properties": {
    "paperRunId":     { "type": "string", "minLength": 1 },
    "candidateId":    { "type": "string", "minLength": 1 },
    "strategyName":   { "type": "string", "minLength": 1 },
    "requestedBy":    { "type": "string", "minLength": 1 },
    "createdAt":      { "type": "string", "format": "date-time" },
    "configHash":     { "type": "string" },
    "rawPayloadJson": { "type": "string" }
  }
}
