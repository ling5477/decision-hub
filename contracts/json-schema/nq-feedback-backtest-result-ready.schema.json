{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decision-hub.guidinglight/contracts/json-schema/nq-feedback-backtest-result-ready.schema.json",
  "title": "BacktestResultReadyPayload",
  "description": "Stage2-PoC-B1：BACKTEST_RESULT_READY payload。requestId 关联 DhBacktestRequest。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "backtestId",
    "requestId",
    "candidateId",
    "periodStart",
    "periodEnd",
    "verdict",
    "readyAt",
    "rawPayloadJson"
  ],
  "properties": {
    "backtestId":     { "type": "string", "minLength": 1 },
    "requestId":      { "type": "string", "minLength": 1 },
    "candidateId":    { "type": "string", "minLength": 1 },
    "sharpeRatio":    { "type": ["number", "null"] },
    "maxDrawdown":    { "type": ["number", "null"] },
    "annualReturn":   { "type": ["number", "null"] },
    "winRate":        { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 },
    "profitFactor":   { "type": ["number", "null"] },
    "periodStart":    { "type": "string", "format": "date" },
    "periodEnd":      { "type": "string", "format": "date" },
    "verdict":        { "type": "string", "enum": ["PASS", "FAIL", "MARGINAL"] },
    "readyAt":        { "type": "string", "format": "date-time" },
    "rawPayloadJson": { "type": "string" }
  }
}
