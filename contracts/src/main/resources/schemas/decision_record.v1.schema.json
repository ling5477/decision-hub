{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "decision_record.v1",
  "title": "DecisionRecord v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "created_at",
    "input_context",
    "model_runs",
    "eval_results",
    "final_decision"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "decision_id": {
      "type": "string",
      "minLength": 8,
      "description": "全局唯一ID，建议 ulid/uuid"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "同一用户请求重跑次数（可选）"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "INIT",
        "RUNNING",
        "DONE",
        "FAILED"
      ],
      "default": "INIT"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64
      },
      "default": []
    },
    "input_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_prompt"
      ],
      "properties": {
        "user_prompt": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "environment": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "context_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "ref"
            ],
            "properties": {
              "type": {
                "type": "string",
                "maxLength": 32
              },
              "ref": {
                "type": "string",
                "maxLength": 256
              }
            }
          },
          "default": []
        }
      }
    },
    "model_runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "run_id",
          "model_name",
          "started_at",
          "finished_at",
          "prompt_snapshot",
          "raw_output",
          "status"
        ],
        "properties": {
          "run_id": {
            "type": "string",
            "minLength": 8
          },
          "model_name": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "type": "string",
            "maxLength": 32,
            "default": "unknown"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "RUNNING",
              "SUCCEEDED",
              "FAILED",
              "SKIPPED"
            ],
            "default": "PENDING"
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "finished_at": {
            "type": "string",
            "format": "date-time"
          },
          "latency_ms": {
            "type": "integer",
            "minimum": 0
          },
          "prompt_snapshot": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "system",
              "user"
            ],
            "properties": {
              "system": {
                "type": "string"
              },
              "developer": {
                "type": "string",
                "default": ""
              },
              "user": {
                "type": "string"
              },
              "tools": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "temperature": {
                "type": "number",
                "minimum": 0,
                "maximum": 2,
                "default": 1
              },
              "top_p": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "default": 1
              }
            }
          },
          "raw_output": {
            "type": "object",
            "additionalProperties": true
          },
          "usage": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "input_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "output_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "total_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "cost_usd": {
                "type": "number",
                "minimum": 0
              }
            },
            "default": {}
          },
          "tool_traces": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "default": []
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      }
    },
    "eval_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evaluator",
          "target",
          "score",
          "passed",
          "reason"
        ],
        "properties": {
          "evaluator": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "ref"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "model_run",
                  "final_decision",
                  "aggregate"
                ]
              },
              "ref": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "passed": {
            "type": "boolean"
          },
          "reason": {
            "type": "string"
          },
          "metrics": {
            "type": "object",
            "additionalProperties": true,
            "default": {}
          }
        }
      },
      "default": []
    },
    "final_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "selected",
        "confidence",
        "output"
      ],
      "properties": {
        "strategy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "majority_vote",
                "weighted_vote",
                "rule_based",
                "llm_judge",
                "hybrid"
              ]
            },
            "params": {
              "type": "object",
              "additionalProperties": true,
              "default": {}
            }
          }
        },
        "selected": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "ref"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "model_run",
                "aggregate"
              ]
            },
            "ref": {
              "type": "string"
            }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "output": {
          "type": "object",
          "additionalProperties": true
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "user_id": {
          "type": "string"
        }
      },
      "default": {}
    }
  }
}